#!/bin/bash
# Wrapper script to run WireCopy with clean console output by default
# Use --verbose flag to see all browser console output

ROOT="$(cd "$(dirname "$0")" && pwd)"

# Use the repo-local .NET 10 SDK wrapper (./dotnet) so we don't pick up a
# system 'dotnet' that's too old to target net10.0 (NETSDK1045). Fall back to a
# 'dotnet' on PATH only if the wrapper isn't present/executable.
if [ -x "$ROOT/dotnet" ]; then
    DOTNET="$ROOT/dotnet"
else
    DOTNET="dotnet"
fi

CFG="${WIRECOPY_BUILD_CONFIG:-Release}"

# ensure_deps: handle the app's runtime dependencies at startup so the user never has to install
# them by hand and never hits a mid-session stall. Safe by design — it only ever downloads the
# Playwright Chromium build (into the per-user cache) and never runs sudo/apt on its own.
#   - Chromium: the web pane streams the API child's own Patchright Chromium. Detect it first
#     (an explicit WIRECOPY_CHROMIUM_EXECUTABLE pin, or the Playwright browsers cache); if missing,
#     install it up front via the built Playwright driver so the ~270MB download happens here at
#     startup instead of lazily on first navigation. On success we export WIRECOPY_BOOTSTRAP_DONE=1
#     so the in-app installer skips the redundant pass. If the driver isn't built yet we leave the
#     flag unset and the in-app safety net (300s timeout) handles it.
#   - ffmpeg/ffprobe: required only for podcast generation. Detect and point the user at the right
#     install command — we never install it for them (no silent sudo).
ensure_deps() {
    if [ -n "${WIRECOPY_CHROMIUM_EXECUTABLE:-}" ] && [ -x "${WIRECOPY_CHROMIUM_EXECUTABLE}" ]; then
        export WIRECOPY_BOOTSTRAP_DONE=1
    else
        local cache="${PLAYWRIGHT_BROWSERS_PATH:-}"
        if [ -z "$cache" ]; then
            case "$(uname -s)" in
                Darwin) cache="$HOME/Library/Caches/ms-playwright" ;;
                *)      cache="$HOME/.cache/ms-playwright" ;;
            esac
        fi
        if [ -n "$(find "$cache" -path '*chromium-*' -type f \( -name chrome -o -name Chromium \) 2>/dev/null | head -1)" ]; then
            export WIRECOPY_BOOTSTRAP_DONE=1
        else
            local pwdir="" rcfg=""
            for d in "$ROOT/src/WireCopy.API/bin/$CFG/net10.0" "$ROOT/src/WireCopy.Web/bin/$CFG/net10.0"; do
                if [ -f "$d/Microsoft.Playwright.dll" ]; then pwdir="$d"; break; fi
            done
            if [ -n "$pwdir" ]; then
                rcfg="$(ls "$pwdir"/WireCopy.*.runtimeconfig.json 2>/dev/null | head -1)"
            fi
            if [ -n "$rcfg" ]; then
                echo "Installing Chromium for the web pane (one-time, ~270 MB)…" >&2
                if "$DOTNET" exec --runtimeconfig "$rcfg" "$pwdir/Microsoft.Playwright.dll" install chromium >&2; then
                    export WIRECOPY_BOOTSTRAP_DONE=1
                else
                    echo "Chromium install did not finish; the app will retry on first navigation." >&2
                fi
            fi
        fi
    fi

    if ! command -v ffmpeg >/dev/null 2>&1 || ! command -v ffprobe >/dev/null 2>&1; then
        echo "Note: ffmpeg/ffprobe not on PATH — podcast generation is unavailable until installed." >&2
        case "$(uname -s)" in
            Darwin) echo "      brew install ffmpeg" >&2 ;;
            *)      echo "      sudo apt-get install ffmpeg   # or your distro's package manager" >&2 ;;
        esac
    fi
}

# find_chrome: locate a headful Chrome/Chromium to host the extension. WIRECOPY_CHROME pin wins; then
# the OS default Chrome/Chromium; then the Playwright "Chrome for Testing" already in the cache. Empty
# output (and exit 1) when none is found, so the caller can fall back to manual load-unpacked.
find_chrome() {
    if [ -n "${WIRECOPY_CHROME:-}" ] && [ -x "${WIRECOPY_CHROME:-}" ]; then echo "$WIRECOPY_CHROME"; return 0; fi
    local c
    case "$(uname -s)" in
        Darwin)
            for c in \
                "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
                "/Applications/Chromium.app/Contents/MacOS/Chromium" \
                "/Applications/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing"; do
                [ -x "$c" ] && { echo "$c"; return 0; }
            done
            ;;
        *)
            for c in google-chrome google-chrome-stable chromium chromium-browser; do
                c="$(command -v "$c" 2>/dev/null)" && [ -n "$c" ] && { echo "$c"; return 0; }
            done
            ;;
    esac
    local cache
    case "$(uname -s)" in
        Darwin) cache="$HOME/Library/Caches/ms-playwright" ;;
        *)      cache="$HOME/.cache/ms-playwright" ;;
    esac
    c="$(find "$cache" -type f \( -name 'Google Chrome for Testing' -o -path '*chrome-linux/chrome' -o -path '*chrome-mac*/Chromium' \) 2>/dev/null | sort | tail -1)"
    [ -n "$c" ] && { echo "$c"; return 0; }
    return 1
}

# launch_extension_browser URL: open a headful Chrome with the CURRENT ./extension loaded, in a
# dedicated persistent profile (so it never clobbers your main Chrome and logins persist across runs).
# Because the extension is loaded fresh at every launch, you never have to reload it by hand — quit this
# window and re-run ./run to pick up extension edits. Best-effort: prints manual steps if no Chrome found.
launch_extension_browser() {
    local url="$1" chrome profile
    if ! chrome="$(find_chrome)"; then
        echo "No Chrome/Chromium found to auto-launch. Load the extension manually:" >&2
        echo "  chrome://extensions -> Developer mode -> Load unpacked -> $ROOT/extension  (then open $url)" >&2
        echo "  (or set WIRECOPY_CHROME=/path/to/chrome and re-run)" >&2
        return 0
    fi
    profile="${WIRECOPY_CHROME_PROFILE:-$HOME/.wirecopy/chrome-profile}"
    mkdir -p "$profile"
    echo "Opening $url in $(basename "$chrome") with the Wire Copy extension (profile: $profile)…" >&2
    echo "  (extension reloads on each ./run — quit this Chrome window and re-run to pick up edits)" >&2
    # WIRECOPY_CHROME_ARGS: extra flags for headless/container/CI hosts (e.g. "--no-sandbox --disable-gpu").
    # Left empty for normal desktop Chrome, which neither needs nor wants them.
    # shellcheck disable=SC2086
    "$chrome" \
        --user-data-dir="$profile" \
        --no-first-run --no-default-browser-check \
        --load-extension="$ROOT/extension" \
        ${WIRECOPY_CHROME_ARGS:-} \
        --new-window "$url" >/dev/null 2>&1 &
}

# Check for --web (browser-hosted shell), --extension (host-browser-as-renderer) and --verbose flags
verbose=false
web=false
extension=false
for arg in "$@"; do
    if [ "$arg" = "--verbose" ]; then
        verbose=true
    fi
    if [ "$arg" = "--web" ]; then
        web=true
    fi
    if [ "$arg" = "--extension" ] || [ "$arg" = "--ext" ]; then
        extension=true
        web=true   # --extension implies the web host
    fi
done

# --web --extension: the host-browser-as-renderer model (workspace-blg5). The Wire Copy overlay docks
# in the user's OWN browser via the Wire Copy Chrome extension; the real site is the tab's own page
# (their profile/cookies, no bot blocks). No server-side content browser, no Xvfb, no Docker — and so
# nothing can pop a stray window. We start WireCopy.Web with WIRECOPY_BROWSER=extension and the user
# loads the extension (chrome://extensions -> Load unpacked -> ./extension), then just browses.
if [ "$web" = true ] && [ "$extension" = true ]; then
    API_EXE="$ROOT/src/WireCopy.API/bin/$CFG/net10.0/WireCopy.API"
    "$DOTNET" build "$ROOT/src/WireCopy.API/WireCopy.API.csproj" -c "$CFG" -v quiet || exit 1
    "$DOTNET" build "$ROOT/src/WireCopy.Web/WireCopy.Web.csproj" -c "$CFG" -v quiet || exit 1
    export WIRECOPY_TERMINAL_APP="$API_EXE"
    export WIRECOPY_TERMINAL_CWD="$ROOT"
    export WIRECOPY_BROWSER=extension
    export WIRECOPY_NO_OPEN=1   # the UI is the extension overlay in your existing browser, not a localhost tab
    WEB_URL="${WIRECOPY_WEB_URL:-http://127.0.0.1:5099}"
    echo "Wire Copy (extension mode) — backend on $WEB_URL" >&2

    # Start the backend, then auto-launch a headful Chrome with the CURRENT ./extension loaded — so every
    # run loads the latest extension files (no manual load-unpacked, no reload, no stale-code guessing).
    # WIRECOPY_NO_CHROME=1 skips the auto-launch (use your own Chrome via load-unpacked).
    "$DOTNET" run --project "$ROOT/src/WireCopy.Web/WireCopy.Web.csproj" -c "$CFG" --no-build &
    WEB_PID=$!
    trap 'kill "$WEB_PID" 2>/dev/null' INT TERM EXIT

    if [ -z "${WIRECOPY_NO_CHROME:-}" ]; then
        printf 'Waiting for the backend' >&2
        for _ in $(seq 1 30); do
            curl -fsS -o /dev/null "$WEB_URL/" 2>/dev/null && break
            kill -0 "$WEB_PID" 2>/dev/null || { echo " — backend exited early." >&2; exit 1; }
            printf '.' >&2; sleep 1
        done
        echo >&2
        launch_extension_browser "$WEB_URL/"
    else
        echo "Load the extension manually: chrome://extensions -> Developer mode -> Load unpacked -> $ROOT/extension" >&2
    fi
    echo "Toggle the overlay with the toolbar button or Alt+Shift+W. Ctrl+C here stops the backend." >&2
    wait "$WEB_PID"
    exit $?
fi

# --web (legacy screencast shell): spawns the unmodified WireCopy.API under a PTY and serves the
# terminal + a CDP-screencast web pane at http://127.0.0.1:5099 (override with WIRECOPY_WEB_URL). The
# API's content browser runs HEADFUL (workspace-8ne3) and is single-window ONLY when it renders to an
# INVISIBLE virtual display (Xvfb) and is streamed into the tab. On a host with a REAL display it would
# pop a separate visible "Chrome for Testing" window — the cardinal single-window violation.
# workspace-3sq1 stopgap: refuse that path and point at the extension (single window by construction)
# or the container, instead of silently popping a stray window. Override: WIRECOPY_FORCE_WEB_LEGACY=1.
if [ "$web" = true ]; then
    real_display=false
    case "$(uname -s)" in
        Darwin) real_display=true ;;                           # macOS always has a visible display, no Xvfb
        Linux)  [ -n "${DISPLAY:-}" ] && real_display=true ;;  # a set DISPLAY means a real X server here
    esac

    if [ "$real_display" = true ] && [ -z "${WIRECOPY_FORCE_WEB_LEGACY:-}" ]; then
        echo "Refusing to launch the legacy --web shell on a real display: its headful content" >&2
        echo "browser would pop a separate window (breaks the single-window rule)." >&2
        echo >&2
        echo "Use the extension instead (single window, your real browser as the renderer):" >&2
        echo "    ./run --web --extension" >&2
        echo "Or run the compliant container (Xvfb virtual display):" >&2
        echo "    docker compose up wirecopy-web   # then open http://127.0.0.1:5099" >&2
        echo >&2
        echo "To force the legacy path anyway (will show a stray window): WIRECOPY_FORCE_WEB_LEGACY=1 ./run --web" >&2
        exit 1
    fi

    API_EXE="$ROOT/src/WireCopy.API/bin/$CFG/net10.0/WireCopy.API"
    "$DOTNET" build "$ROOT/src/WireCopy.API/WireCopy.API.csproj" -c "$CFG" -v quiet || exit 1
    "$DOTNET" build "$ROOT/src/WireCopy.Web/WireCopy.Web.csproj" -c "$CFG" -v quiet || exit 1
    ensure_deps
    export WIRECOPY_TERMINAL_APP="$API_EXE"
    export WIRECOPY_TERMINAL_CWD="$ROOT"

    # Linux with no real display: provide a virtual one so the headful content browser stays invisible
    # (single-window via the screencast) instead of failing to launch.
    if [ "$(uname -s)" = Linux ] && [ -z "${DISPLAY:-}" ] && command -v xvfb-run >/dev/null 2>&1; then
        exec xvfb-run -a --server-args="-screen 0 1280x2400x24" \
            "$DOTNET" run --project "$ROOT/src/WireCopy.Web/WireCopy.Web.csproj" -c "$CFG" --no-build
    fi
    exec "$DOTNET" run --project "$ROOT/src/WireCopy.Web/WireCopy.Web.csproj" -c "$CFG" --no-build
fi

ensure_deps

# Run with or without filtering
if [ "$verbose" = true ]; then
    # Verbose mode: show everything
    "$DOTNET" run --project src/WireCopy.API --configuration Release -- "$@"
else
    # Default mode: filter browser noise
    "$DOTNET" run --project src/WireCopy.API --configuration Release -- "$@" 2>&1 | \
      grep -v "console.error:" | \
      grep -v "NS_ERROR_CONTENT_BLOCKED" | \
      grep -v "geckodriver" | \
      grep -v "You are running in headless mode" | \
      grep -v "Read port:" | \
      grep -v "RenderCompositorSWGL" | \
      grep -v "AVCaptureDeviceTypeExternal" | \
      grep -v "FaviconLoader.sys.mjs" | \
      grep -v "getpocket.com" | \
      grep -v "OHTTP was configured" | \
      grep -v "ContextId.sys.mjs" | \
      grep -v "^\[GFX" | \
      grep -v "^[0-9]*[[:space:]]*firefox\[" | \
      grep -v "TypeError.*NetworkError.*Failed to fetch"
fi
