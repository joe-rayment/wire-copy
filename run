#!/bin/bash
# Wrapper script to run WireCopy with clean console output by default
# Use --verbose flag to see all browser console output

# Resolve the repo root and use the vendored .NET SDK wrapper (./dotnet), which bootstraps the pinned
# .NET 10 SDK on first use. This avoids "NETSDK1045: does not support targeting .NET 10.0" when the
# system 'dotnet' is an older SDK (e.g. 9.x). Run from anywhere.
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"
DOTNET="$ROOT/dotnet"

# Check if --verbose is in the arguments
verbose=false
for arg in "$@"; do
    if [ "$arg" = "--verbose" ]; then
        verbose=true
        break
    fi
done

# NEVER-HEADLESS POLICY (workspace-8ne3): WireCopy runs a REAL HEADFUL browser — never headless (headless is
# bot-detected/blocked on the sites it targets). On Linux without a display, provide a VIRTUAL display (Xvfb)
# so the browser is still headful; the app must NEVER silently degrade to headless. macOS/Windows and Linux
# with a real DISPLAY run directly.
launch=()
if [ "$(uname)" = "Linux" ] && [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ]; then
    if command -v xvfb-run >/dev/null 2>&1; then
        echo "wirecopy: no display detected — starting a virtual display (Xvfb) so the browser stays headful (never headless)." >&2
        launch=(xvfb-run -a --server-args="-screen 0 1600x1200x24")
    else
        echo "wirecopy: ERROR — no display and 'xvfb-run' is not installed. WireCopy never runs headless." >&2
        echo "  Install Xvfb (Debian/Ubuntu: sudo apt-get install xvfb; Fedora: sudo dnf install xorg-x11-server-Xvfb)," >&2
        echo "  or attach a real display, then re-run ./run." >&2
        exit 1
    fi
fi

# Run with or without filtering.
#
# The TUI renders ANSI frames to STDOUT (TerminalPageRenderer → Console.Out) and reads keys from STDIN, so
# stdout/stdin MUST stay attached to the real terminal — piping stdout through grep mangles the frames and
# the TUI never takes over the screen. The app's own logs go to logs/ (file-only in browse mode), so the
# only console noise is the browser subprocess on STDERR. Default mode therefore filters ONLY stderr,
# leaving stdout on the TTY for the TUI; --verbose shows everything unfiltered.
if [ "$verbose" = true ]; then
    # Verbose mode: show everything
    "${launch[@]}" "$DOTNET" run --project src/WireCopy.API --configuration Release -- "$@"
else
    # Default mode: TUI on the real terminal (stdout), filter browser noise on stderr only.
    "${launch[@]}" "$DOTNET" run --project src/WireCopy.API --configuration Release -- "$@" \
      2> >(grep --line-buffered -v \
        -e "console.error:" \
        -e "NS_ERROR_CONTENT_BLOCKED" \
        -e "geckodriver" \
        -e "Read port:" \
        -e "RenderCompositorSWGL" \
        -e "AVCaptureDeviceTypeExternal" \
        -e "FaviconLoader.sys.mjs" \
        -e "getpocket.com" \
        -e "OHTTP was configured" \
        -e "ContextId.sys.mjs" \
        -e "^\[GFX" \
        -e "^[0-9]*[[:space:]]*firefox\[" \
        -e "TypeError.*NetworkError.*Failed to fetch" >&2)
fi
