{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/wirecopy-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Browser": {
    "Headless": false,
    "ImplicitWaitSeconds": 30,
    "PageLoadTimeoutSeconds": 300,
    "DisableImages": true,
    "DisableJavaScript": false
  },
  "OpenAiTts": {
    "Model": "tts-1",
    "Voice": "nova",
    "Speed": 1.0,
    "OutputFormat": "aac",
    "MaxChunkSize": 4096,
    "MaxBudgetUsd": 1.0,
    "MaxRetries": 3,
    "RetryBaseDelayMs": 1000,
    "InterChunkDelayMs": 200
  },
  "Chatterbox": {
    "UvPath": "uv",
    "UvArgs": "run --python 3.11 --with chatterbox-tts==0.1.7 --with \"setuptools<81\"",
    "WorkerRelativePath": "chatterbox-worker/chatterbox_worker.py",
    "Device": "auto",
    "CfgWeight": 0.5,
    "DefaultExaggeration": 0.5,
    "MaxChunkSize": 300,
    "StartTimeoutSeconds": 120,
    "LoadTimeoutSeconds": 1800,
    "SpeakTimeoutSecondsPerChunk": 600
  },
  "Podcast": {
    "AudioCodec": "aac",
    "AudioBitrate": "64k",
    "AudioChannels": 1,
    "SampleRate": 44100,
    "UseNeroChapters": true,
    "Title": "WireCopy Podcast",
    "Description": "Articles converted to audio by WireCopy.",
    "Author": "WireCopy",
    "Language": "en-us",
    "Category": "News",
    "Explicit": false
  },
  "TtsAudioCache": {
    "MaxSizeBytes": 524288000,
    "Ttl": "30.00:00:00"
  },
  "OpenAiHierarchy": {
    "Model": "gpt-5-mini",
    "ReasoningEffort": "minimal",
    "MaxTokens": 4096,
    "AiCuratedCacheDays": 30
  },
  "Gcs": {
    "CreateBucketIfNotExists": true,
    "BucketLocation": "US"
  }
}