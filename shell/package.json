{
  "name": "wirecopy-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "WireCopy Desktop — single-window shell: real headful Chromium hosting the WireCopy TUI in an owned terminal pane (never headless)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "43.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.wirecopy.desktop",
    "productName": "WireCopy",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "popup-preload.js",
      "channel.js",
      "term.html",
      "fonts/**"
    ],
    "extraResources": [
      {
        "from": "stage-api",
        "to": "api"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Network",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null,
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  }
}
